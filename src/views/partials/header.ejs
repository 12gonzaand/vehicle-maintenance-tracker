<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1, viewport-fit=cover, user-scalable=no">
  <title><%= typeof title !== 'undefined' ? title : 'Maintenance Tracker' %></title>
  <link rel="stylesheet" href="/public/css/style.css">
  <link rel="apple-touch-icon" href="/public/icons/apple-touch-icon.png">
  <link rel="icon" type="image/svg+xml" href="/public/icons/favicon.svg">
  <link rel="icon" type="image/png" sizes="32x32" href="/public/icons/favicon-32x32.png">
  <link rel="manifest" href="/public/manifest.json">
  <meta name="apple-mobile-web-app-capable" content="yes">
  <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
  <meta name="apple-mobile-web-app-title" content="Maintenance">
  <meta name="theme-color" content="#171717">
</head>
<body>
  <header class="site-header page-header">
    <a href="/vehicles" class="brand">Maintenance Tracker</a>
    <% if (typeof session !== 'undefined' && session && session.authenticated) { %>
      <form method="post" action="/logout" class="inline-form">
        <button type="submit" class="btn btn-small">Log Out</button>
      </form>
    <% } %>
  </header>
  <main class="container">
