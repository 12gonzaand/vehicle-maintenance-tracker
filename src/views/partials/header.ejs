<!doctype html>
<html lang="en">
<head>
  <meta charset="utf-8">
  <meta name="viewport" content="width=device-width, initial-scale=1">
  <title><%= typeof title !== 'undefined' ? title : 'Maintenance Tracker' %></title>
  <link rel="stylesheet" href="/public/css/style.css">
  <link rel="apple-touch-icon" href="/public/icons/apple-touch-icon.png">
  <link rel="icon" href="/public/icons/apple-touch-icon.png">
  <meta name="apple-mobile-web-app-title" content="Maintenance">
</head>
<body>
  <header class="site-header page-header">
    <a href="/vehicles" class="brand">Maintenance Tracker</a>
    <% if (typeof session !== 'undefined' && session && session.authenticated) { %>
      <form method="post" action="/logout" class="inline-form">
        <button type="submit" class="btn btn-small">Log Out</button>
      </form>
    <% } %>
  </header>
  <main class="container">
